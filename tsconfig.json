{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"exclude": ["node_modules", "oxfmt.config.ts", "oxlint.config.ts"]
}
